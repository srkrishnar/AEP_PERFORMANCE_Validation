<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="ECommerce_Performance_TestPlan">
      <stringProp name="TestPlan.comments">Enterprise e-commerce performance test. 15 endpoints, 50 VUs, 5-min duration. Override via CLI: -JHOST=x -JPORT=y -JTHREAD_COUNT=z</stringProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
    </TestPlan>
    <hashTree>
      <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="UDV_Global_Config">
        <collectionProp name="Arguments.arguments">
          <elementProp name="PROTOCOL" elementType="Argument">
            <stringProp name="Argument.name">PROTOCOL</stringProp>
            <stringProp name="Argument.value">${__P(PROTOCOL,http)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Communication protocol used (http or https)</stringProp>
          </elementProp>
          <elementProp name="HOST" elementType="Argument">
            <stringProp name="Argument.name">HOST</stringProp>
            <stringProp name="Argument.value">${__P(HOST,172.30.62.25)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">IP address of the server being tested</stringProp>
          </elementProp>
          <elementProp name="PORT" elementType="Argument">
            <stringProp name="Argument.name">PORT</stringProp>
            <stringProp name="Argument.value">${__P(PORT,32049)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Port number the server is listening on</stringProp>
          </elementProp>
          <elementProp name="THREAD_COUNT" elementType="Argument">
            <stringProp name="Argument.name">THREAD_COUNT</stringProp>
            <stringProp name="Argument.value">${__P(THREAD_COUNT,5)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Number of virtual users hitting the server</stringProp>
          </elementProp>
          <elementProp name="RAMP_UP" elementType="Argument">
            <stringProp name="Argument.name">RAMP_UP</stringProp>
            <stringProp name="Argument.value">${__P(RAMP_UP,5)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Time to bring all users online gradually - 5 Sec</stringProp>
          </elementProp>
          <elementProp name="DURATION" elementType="Argument">
            <stringProp name="Argument.name">DURATION</stringProp>
            <stringProp name="Argument.value">${__P(DURATION,300)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Total time the test runs - 300 sec - 5 min</stringProp>
          </elementProp>
          <elementProp name="THINK_TIME_MEAN" elementType="Argument">
            <stringProp name="Argument.name">THINK_TIME_MEAN</stringProp>
            <stringProp name="Argument.value">${__P(THINK_TIME_MEAN,1000)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Average pause between user actions - 1000 ms = 1 sec</stringProp>
          </elementProp>
          <elementProp name="THINK_TIME_DEV" elementType="Argument">
            <stringProp name="Argument.name">THINK_TIME_DEV</stringProp>
            <stringProp name="Argument.value">${__P(THINK_TIME_DEV,3000)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">How much the pause can vary - 3000 ms = 3 secs</stringProp>
          </elementProp>
          <elementProp name="CONNECT_TIMEOUT" elementType="Argument">
            <stringProp name="Argument.name">CONNECT_TIMEOUT</stringProp>
            <stringProp name="Argument.value">${__P(CONNECT_TIMEOUT,5000)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Max wait time to establish server connection - 5000 ms = 5 secs</stringProp>
          </elementProp>
          <elementProp name="RESPONSE_TIMEOUT" elementType="Argument">
            <stringProp name="Argument.name">RESPONSE_TIMEOUT</stringProp>
            <stringProp name="Argument.value">${__P(RESPONSE_TIMEOUT,30000)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Max wait time for server to send a response - 30000 ms = 30 secs</stringProp>
          </elementProp>
          <elementProp name="SLA_RESPONSE_TIME" elementType="Argument">
            <stringProp name="Argument.name">SLA_RESPONSE_TIME</stringProp>
            <stringProp name="Argument.value">${__P(SLA_RESPONSE_TIME,3000)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Acceptable response time limit (pass/fail threshold) - 3000 ms = 3 secs</stringProp>
          </elementProp>
          <elementProp name="PRODUCT_ID_1" elementType="Argument">
            <stringProp name="Argument.name">PRODUCT_ID_1</stringProp>
            <stringProp name="Argument.value">B00CP92UHU</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Test product ID 1 used in</stringProp>
          </elementProp>
          <elementProp name="PRODUCT_ID_2" elementType="Argument">
            <stringProp name="Argument.name">PRODUCT_ID_2</stringProp>
            <stringProp name="Argument.value">B0775268NR</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Test product ID 2 used in</stringProp>
          </elementProp>
        </collectionProp>
      </Arguments>
      <hashTree/>
      <ConfigTestElement guiclass="HttpDefaultsGui" testclass="ConfigTestElement" testname="HTTP_Request_Defaults" enabled="true">
        <stringProp name="HTTPSampler.connect_timeout">${CONNECT_TIMEOUT}</stringProp>
