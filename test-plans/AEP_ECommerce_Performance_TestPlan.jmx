            <hashTree/>
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="RA_CheckoutProcess_200" enabled="true">
              <collectionProp name="Asserion.test_strings">
                <stringProp name="49586">200</stringProp>
              </collectionProp>
              <stringProp name="Assertion.custom_message">FAIL: Checkout process API did not return HTTP 200</stringProp>
              <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
              <boolProp name="Assertion.assume_success">false</boolProp>
              <intProp name="Assertion.test_type">8</intProp>
            </ResponseAssertion>
            <hashTree/>
            <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion" testname="DA_CheckoutProcess_SLA" enabled="true">
              <stringProp name="DurationAssertion.duration">${SLA_RESPONSE_TIME}</stringProp>
            </DurationAssertion>
            <hashTree/>
            <!-- Extract checkout fields into JMeter vars for TC_17 Place Order payload -->
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="EX_Checkout_ExtractFields" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
import groovy.json.JsonSlurper
import groovy.json.JsonOutput
def body = prev.getResponseDataAsString()
if (!body || body.trim().isEmpty()) { return }
try {
  def json = new JsonSlurper().parseText(body)
  vars.put('CHECKOUT_ORDER_SUMMARY',   JsonOutput.toJson(json?.orderSummary   ?: [:]))
  vars.put('CHECKOUT_REVIEW_ORDER',    JsonOutput.toJson(json?.reviewOrder    ?: [:]))
  vars.put('CHECKOUT_DELIVERY_ADDRESS',JsonOutput.toJson(json?.deliveryAddress ?: [:]))
} catch (Exception e) {
  vars.put('CHECKOUT_ORDER_SUMMARY',   '{}')
  vars.put('CHECKOUT_REVIEW_ORDER',    '{}')
  vars.put('CHECKOUT_DELIVERY_ADDRESS','{}')
  log.warn('EX_Checkout_ExtractFields: ' + e.message)
}
              </stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>
